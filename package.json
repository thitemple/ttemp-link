{
	"name": "ttemp-link",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.6",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"format": "bun run --cwd apps/admin format && bun run --cwd apps/redirect format && prettier --write README.md .github/workflows/deploy-admin.yml .github/workflows/deploy-redirect.yml package.json && prettier --write --parser json captain-definition-admin captain-definition-redirect",
		"preview": "turbo preview",
		"lint": "turbo lint",
		"check": "turbo check",
		"test": "turbo test",
		"tests": "bun run test",
		"db:start": "docker compose up -d",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.2",
		"drizzle-kit": "^0.31.8",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"turbo": "^2.0.14",
		"typescript-eslint": "^8.53.1"
	}
}
